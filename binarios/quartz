#!/usr/bin/env bash

# CRITICAL: Enable alias expansion inside functions
shopt -s expand_aliases

# Source shell config to load aliases
[ -f ~/.bashrc ] && source ~/.bashrc
[ -f ~/.bash_profile ] && source ~/.bash_profile
[ -f ~/.zshrc ] && source ~/.zshrc 2>/dev/null

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m'

# Print header
print_header() {
    echo -e "${CYAN}════════════════════════════════════════════${NC}"
    echo -e "${CYAN}$1${NC}"
    echo -e "${CYAN}════════════════════════════════════════════${NC}"
}

print_step() {
    echo -e "\n${BLUE}▶${NC} ${WHITE}$1${NC}"
}

print_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_error() {
    echo -e "${RED}❌ $1${NC}"
}

# Main menu
show_menu() {
    clear
    print_header "SCRIPT MANAGER"
    echo ""
    echo -e "${MAGENTA}Select an option:${NC}"
    echo ""
    echo -e "${YELLOW}1${NC}) syncquartz  ${CYAN}# Push new notes to server${NC}"
    echo -e "${YELLOW}2${NC}) quartzbuild ${CYAN}# Generate static site via SSH${NC}"
    echo -e "${YELLOW}3${NC}) syncobsi    ${CYAN}# Pull site to local GitHub repo${NC}"
    echo -e "${RED}0${NC}) Exit"
    echo ""
}

# Main loop
while true; do
    show_menu
    read -n 1 -p "$(echo -e ${CYAN}Option:${NC}) " option
    echo ""
    
    case $option in
        1)
            print_header "📤 SYNC NOTES"
            print_step "Running: syncquartz"
            syncquartz
            status=$?
            echo ""
            if [ $status -eq 0 ]; then
                print_success "syncquartz completed"
            else
                print_error "syncquartz failed (exit code: $status)"
            fi
            echo ""
            read -n 1 -s -p "Press any key to continue..."
            ;;
        2)
            print_header "🏗️  BUILD WEBSITE"
            print_step "Running: quartzbuild"
            quartzbuild
            status=$?
            echo ""
            if [ $status -eq 0 ]; then
                print_success "quartzbuild completed"
            else
                print_error "quartzbuild failed (exit code: $status)"
            fi
            echo ""
            read -n 1 -s -p "Press any key to continue..."
            ;;
        3)
            print_header "📦 SYNC TO GITHUB"
            print_step "Running: syncobsi"
            syncobsi
            status=$?
            echo ""
            if [ $status -eq 0 ]; then
                print_success "syncobsi completed"
            else
                print_error "syncobsi failed (exit code: $status)"
            fi
            echo ""
            read -n 1 -s -p "Press any key to continue..."
            ;;
        0)
            echo -e "\n${CYAN}Goodbye!${NC}"
            break
            ;;
        *)
            echo -e "\n${RED}Invalid option${NC}"
            sleep 1
            ;;
    esac
done
