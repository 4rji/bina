#!/usr/bin/env bash

# ====== CONFIG ======
LOCAL_NOTES="$HOME/github/Obsidian-Notes/"
REMOTE_HOST="debian-server"
REMOTE_QUARTZ_DIR="/home/nala/quartz"
REMOTE_CONTENT_DIR="$REMOTE_QUARTZ_DIR/content/"
REMOTE_PUBLIC_DIR="$REMOTE_QUARTZ_DIR/public/"
LOCAL_WEBSITE="$HOME/github/Obsidian-Notes-website/"

# ====== FUNCIONES ======
sync_notes() {
  rsync -av --delete --exclude=".*" \
    "$LOCAL_NOTES" \
    "$REMOTE_HOST:$REMOTE_CONTENT_DIR"
}

build_quartz() {
  ssh "$REMOTE_HOST" '
    export NVM_DIR="$HOME/.nvm" &&
    . "$NVM_DIR/nvm.sh" &&
    nvm use 22 &&
    cd '"$REMOTE_QUARTZ_DIR"' &&
    npx quartz build
  '
}

sync_website() {
  rsync -av --delete \
    --exclude=".git" \
    --exclude=".gitignore" \
    --exclude=".gitattributes" \
    "$REMOTE_HOST:$REMOTE_PUBLIC_DIR" \
    "$LOCAL_WEBSITE"
}

run_all() {
  sync_notes
  build_quartz
  sync_website
}

# ====== CHECK GUM ======
if ! command -v gum >/dev/null 2>&1; then
  read -rp "gum no está instalado. ¿Continuar con menú básico? (y/n): " yn
  [[ "$yn" != "y" ]] && exit 1

  echo "1) Sync notes -> server"
  echo "2) Build Quartz"
  echo "3) Sync website -> local"
  echo "4) Run ALL"
  echo "0) Exit"
  read -rp "Select: " opt
else
  opt=$(gum choose \
    "Sync notes -> server" \
    "Build Quartz" \
    "Sync website -> local" \
    "Run ALL" \
    "Exit")
fi

# ====== EXEC ======
case $opt in
  1|"Sync notes -> server") sync_notes ;;
  2|"Build Quartz") build_quartz ;;
  3|"Sync website -> local") sync_website ;;
  4|"Run ALL") run_all ;;
  0|"Exit") exit 0 ;;
  *) echo "Invalid option" ;;
esac