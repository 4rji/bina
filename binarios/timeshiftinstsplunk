#!/usr/bin/env bash
set -euo pipefail

sudo dnf install -y oracle-epel-release-el9
sudo dnf install -y timeshift rsync util-linux

CFG="/etc/timeshift/timeshift.json"
DEFAULT="/etc/timeshift/default.json"

# 0) Asegura que exista timeshift.json (si no, créalo desde default.json)
if [[ ! -f "$CFG" ]]; then
  if [[ -f "$DEFAULT" ]]; then
    echo "[*] No existe $CFG. Creando desde $DEFAULT..."
    sudo cp -a "$DEFAULT" "$CFG"
  else
    echo "[!] No existe $DEFAULT. Abre Timeshift una vez para generar la config."
    exit 1
  fi
fi

# 1) Backup del JSON (si no existe aún)
LATEST_BK="$(ls -1t /etc/timeshift/timeshift.json.bak.* 2>/dev/null | head -n1 || true)"
if [[ -z "${LATEST_BK}" ]]; then
  TS="$(date +%Y%m%d-%H%M%S)"
  LATEST_BK="/etc/timeshift/timeshift.json.bak.$TS"
  echo "[*] No encontré backups. Creando: $LATEST_BK"
  sudo cp -a "$CFG" "$LATEST_BK"
else
  echo "[+] Latest backup: $LATEST_BK"
fi

# 2) Si el JSON actual está roto, restaura backup
if ! sudo python3 -c 'import json; json.load(open("/etc/timeshift/timeshift.json","r",encoding="utf-8"))' 2>/dev/null; then
  echo "[!] JSON roto, restaurando backup..."
  sudo cp -a "$LATEST_BK" "$CFG"
fi

# 3) Fuerza destino LOCAL = filesystem montado en "/" (NO /boot)
ROOT_SRC="$(findmnt -no SOURCE /)"
ROOT_UUID="$(sudo blkid -s UUID -o value "$ROOT_SRC" 2>/dev/null || true)"

if [[ -z "${ROOT_UUID}" ]]; then
  echo "[!] No pude obtener UUID del root ($ROOT_SRC)."
  echo "    Revisa: findmnt -no SOURCE / && sudo blkid <eso>"
  exit 1
fi

echo "[+] Root SOURCE: $ROOT_SRC"
echo "[+] Root UUID  : $ROOT_UUID"

sudo mkdir -p /timeshift
sudo chmod 700 /timeshift || true

sudo python3 - <<PY
import json
cfg_path = "$CFG"
with open(cfg_path, "r", encoding="utf-8") as f:
    data = json.load(f)

data["backup_device_uuid"] = "$ROOT_UUID"
data["backup_device"] = ""
data["backup_directory"] = "/timeshift"
data["snapshot_device"] = ""
data["snapshot_device_uuid"] = ""

data["exclude"] = [
    "/var/log/**",
    "/var/cache/**",
    "/var/tmp/**",
    "/tmp/**",
    "/media/**",
    "/mnt/**",
    "/dev/**",
    "/proc/**",
    "/sys/**",
    "/run/**",
    "/home/**",

    # Splunk: excluye data/logs grandes
    "/opt/splunk/var/**",
    "/opt/splunkforwarder/var/**",
]

with open(cfg_path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2, sort_keys=False)
    f.write("\\n")

print("[+] Config local aplicada: backup_device_uuid(root) + excludes + /timeshift")
PY

# 4) Guarda un TAR del config de Splunk dentro de /etc/timeshift (queda dentro del snapshot)
OUT_DIR="/etc/timeshift"
TS="$(date +%Y%m%d-%H%M%S)"
OUT_FILE="$OUT_DIR/splunk-etc-$TS.tar.gz"

SPLUNK_ETC_DIRS=()
[[ -d /opt/splunk/etc ]] && SPLUNK_ETC_DIRS+=("/opt/splunk/etc")
[[ -d /opt/splunkforwarder/etc ]] && SPLUNK_ETC_DIRS+=("/opt/splunkforwarder/etc")

if (( ${#SPLUNK_ETC_DIRS[@]} > 0 )); then
  sudo tar -czf "$OUT_FILE" --absolute-names "${SPLUNK_ETC_DIRS[@]}"
  sudo ln -sfn "$(basename "$OUT_FILE")" "$OUT_DIR/splunk-etc-latest.tar.gz"
  echo "[+] Splunk config guardado: $OUT_FILE"
else
  echo "[i] No encontré /opt/splunk{,forwarder}/etc; no guardé tar de Splunk."
fi
echo "to restart splunk config"
echo "sudo tar -xzf /etc/timeshift/splunk-etc-latest.tar.gz -C /"
echo "[+] Listo. Snapshot local se guardará en /timeshift/snapshots (dentro de /)."
echo "    Crea uno con:"
echo "    sudo timeshift --create --comments \"baseline local\" --tags D"