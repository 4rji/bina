#!/usr/bin/env bash
set -euo pipefail

# Lista de paquetes a instalar
paquetes=("timeshift")

# Función para verificar si un paquete está instalado (Debian/Ubuntu/Kali)
paquete_instalado_apt() {
    dpkg -l "$1" | grep -q '^ii'
}

# Función para verificar si un paquete está instalado (CentOS/RHEL)
paquete_instalado_yum() {
    yum list installed "$1" &> /dev/null
}

# Función para verificar si un paquete está instalado (Fedora)
paquete_instalado_dnf() {
    dnf list installed "$1" &> /dev/null
}

# Función para verificar si un paquete está instalado (Arch Linux)
paquete_instalado_pacman() {
    pacman -Qi "$1" &> /dev/null
}

# Detectar el sistema operativo
if [ -f /etc/os-release ]; then
    . /etc/os-release
    OS=$ID
fi

# Instalar paquetes basados en el sistema operativo
for paquete in "${paquetes[@]}"; do
    case $OS in
        "debian"|"ubuntu"|"kali")
            if ! paquete_instalado_apt "$paquete"; then
                echo "Instalando el paquete $paquete..."
                sudo apt-get update -y
                sudo apt-get install -y "$paquete"
            fi
            ;;
        "centos"|"rhel")
            if ! paquete_instalado_yum "$paquete"; then
                echo "Instalando el paquete $paquete..."
                sudo yum install -y "$paquete"
            fi
            ;;
        "fedora")
            if ! paquete_instalado_dnf "$paquete"; then
                echo "Instalando el paquete $paquete..."
                sudo dnf install -y "$paquete"
            fi
            ;;
        "arch")
            if ! paquete_instalado_pacman "$paquete"; then
                echo "Instalando el paquete $paquete..."
                sudo pacman -S --noconfirm "$paquete"
            fi
            ;;
        *)
            echo "[!] OS no soportado: ${OS:-unknown}"
            ;;
    esac
done

CFG="/etc/timeshift/timeshift.json"

# 1) Encuentra el backup más reciente
LATEST_BK="$(ls -1t /etc/timeshift/timeshift.json.bak.* 2>/dev/null | head -n1 || true)"
if [[ -z "${LATEST_BK}" ]]; then
  echo "No encontré backups /etc/timeshift/timeshift.json.bak.*"
  exit 1
fi

echo "[+] Latest backup: $LATEST_BK"

# 2) Si el JSON actual está roto, restaura backup
if ! sudo python3 -c 'import json; json.load(open("/etc/timeshift/timeshift.json","r",encoding="utf-8"))' 2>/dev/null; then
  echo "[!] JSON roto, restaurando backup..."
  sudo cp -a "$LATEST_BK" "$CFG"
fi

# 3) Aplica exclude minimal (CCDC) + excluye datos/logs de Splunk, pero deja /opt/splunk/etc
sudo python3 - <<'PY'
import json

cfg_path = "/etc/timeshift/timeshift.json"

with open(cfg_path, "r", encoding="utf-8") as f:
    data = json.load(f)

data["exclude"] = [
    "/var/log/**",
    "/var/cache/**",
    "/var/tmp/**",
    "/tmp/**",
    "/media/**",
    "/mnt/**",
    "/dev/**",
    "/proc/**",
    "/sys/**",
    "/run/**",
    "/home/**",

    # Splunk: excluye data/logs grandes
    "/opt/splunk/var/**",
    "/opt/splunkforwarder/var/**",
]

with open(cfg_path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2, sort_keys=False)
    f.write("\n")

print("[+] exclude aplicado OK (incluye regla Splunk var/**)")
PY

# 4) Guarda un TAR del config de Splunk dentro de /etc/timeshift (queda dentro del snapshot)
OUT_DIR="/etc/timeshift"
TS="$(date +%Y%m%d-%H%M%S)"
OUT_FILE="$OUT_DIR/splunk-etc-$TS.tar.gz"

SPLUNK_ETC_DIRS=()
[[ -d /opt/splunk/etc ]] && SPLUNK_ETC_DIRS+=("/opt/splunk/etc")
[[ -d /opt/splunkforwarder/etc ]] && SPLUNK_ETC_DIRS+=("/opt/splunkforwarder/etc")

if (( ${#SPLUNK_ETC_DIRS[@]} > 0 )); then
  sudo tar -czf "$OUT_FILE" --absolute-names "${SPLUNK_ETC_DIRS[@]}"
  sudo ln -sfn "$(basename "$OUT_FILE")" "$OUT_DIR/splunk-etc-latest.tar.gz"
  echo "[+] Splunk config guardado: $OUT_FILE"
else
  echo "[i] No encontré /opt/splunk{,forwarder}/etc; no guardé tar de Splunk."
fi

echo "[+] Listo. Revisa:"
echo "    sudo python3 -c 'import json; json.load(open(\"$CFG\")); print(\"JSON OK\")'"
echo "    sudo grep -n '\"exclude\"' -n $CFG | head"
echo "    ls -l /etc/timeshift/splunk-etc-*.tar.gz /etc/timeshift/splunk-etc-latest.tar.gz 2>/dev/null || true"
