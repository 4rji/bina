#!/usr/bin/env bash

set -u

commit_msg="naal2"

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
NC="\033[0m"

run_cmd() {
  echo -e "\n${CYAN}>> $*${NC}"
  "$@"
  code=$?
  echo
  if [ $code -eq 0 ]; then
    echo -e "${GREEN}OK${NC}"
  else
    echo -e "${RED}Failed with code: $code${NC}"
  fi
  echo
  sleep 1
}

show_menu() {
  clear
  echo -e "${YELLOW}=============================="
  echo "        GIT QUICK MENU"
  echo -e "==============================${NC}"
  echo "Repo: $(basename "$(pwd)")"
  echo "Path: $(pwd)"
  echo
  echo -e "${CYAN}1)${NC} git add . && git commit -m \"${commit_msg}\" && git push"
  echo -e "${CYAN}2)${NC} git status"
  echo -e "${CYAN}3)${NC} git fetch && git pull"
  echo -e "${CYAN}q)${NC} Exit"
  echo
  echo -e "Commit message fixed: ${GREEN}${commit_msg}${NC}"
  echo -e "Select with one key. No Enter needed."
}

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo -e "${RED}Not a git repo${NC}"; exit 1; }

while true; do
  show_menu
  read -rsn1 opt
  echo

  case "$opt" in
    1)
      echo -e "\n${CYAN}Running commit flow...${NC}"
      git add . && git commit -m "$commit_msg" && git push
      code=$?
      echo
      if [ $code -eq 0 ]; then
        echo -e "${GREEN}OK${NC}"
      else
        echo -e "${RED}Failed with code: $code${NC}"
      fi
      echo
      sleep 1
      ;;
    2) run_cmd git status ;;
    3)
      echo -e "\n${CYAN}Running fetch + pull...${NC}"
      git fetch && git pull
      code=$?
      echo
      if [ $code -eq 0 ]; then
        echo -e "${GREEN}OK${NC}"
      else
        echo -e "${RED}Failed with code: $code${NC}"
      fi
      echo
      sleep 1
      ;;
    q|Q) echo -e "${YELLOW}Bye${NC}"; exit 0 ;;
    *) echo -e "${RED}Invalid${NC}"; sleep 1 ;;
  esac
done
