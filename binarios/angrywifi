#!/usr/bin/env bash

set -u

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

GPSD_ENDPOINT="127.0.0.1:2947"
USE_GPSD=0

show_usage() {
    cat <<EOF
${BOLD}Usage:${RESET} angrywifi [options]

${BOLD}Options:${RESET}
  -i, --install       Download AngryOxide
  -g, --gps           Start AngryOxide with GPSD support (${GPSD_ENDPOINT})
  -h, --help          Show this help

${BOLD}Examples:${RESET}
  angrywifi
  angrywifi -g
  angrywifi --gps
EOF
}

install_angryoxide() {
    mkdir -p "$HOME/.angry"

    echo "${BOLD}${CYAN}Select a download option:${RESET}"
    echo "${YELLOW}1)${RESET} Linux AMD64 x86_64"
    echo "${YELLOW}2)${RESET} Linux AArch64"
    echo "${YELLOW}3)${RESET} Linux ARM"
    echo

    read -r -p "Enter the option number: " option

    case "$option" in
        1)
            wget https://github.com/Ragnt/AngryOxide/releases/download/v0.8.28/angryoxide-linux-x86_64.tar.gz -P "$HOME/.angry/"
            ;;
        2)
            wget https://github.com/Ragnt/AngryOxide/releases/download/v0.8.9/angryoxide-linux-aarch64-musl.tar.gz -P "$HOME/.angry/"
            ;;
        3)
            wget https://github.com/Ragnt/AngryOxide/releases/download/v0.8.9/angryoxide-linux-arm-musl.tar.gz -P "$HOME/.angry/"
            ;;
        *)
            echo "${RED}Invalid option. Exiting.${RESET}"
            return 1
            ;;
    esac

    cd "$HOME/.angry" || return 1

    downloaded_file=$(basename "$(ls -t1 | head -n1)")

    if [ -f "$downloaded_file" ]; then
        if tar -xf "$downloaded_file"; then
            echo "${GREEN}Download and extraction completed successfully in ~/.angry${RESET}"
        else
            echo "${RED}An error occurred while extracting the archive.${RESET}"
            echo "${YELLOW}Run 'sudo install.sh install' manually if needed, then run 'angry'.${RESET}"
            return 1
        fi
    else
        echo "${RED}An error occurred during the download.${RESET}"
        echo "${YELLOW}Run 'sudo install.sh install' manually if needed, then run 'angry'.${RESET}"
        return 1
    fi
}

choose_interface() {
    mapfile -t interfaces < <(ip -o link show | awk -F': ' '{split($2, iface, "@"); print iface[1]}')
    menu_options=()

    if [ "${#interfaces[@]}" -eq 0 ]; then
        echo "${RED}No network interfaces found.${RESET}"
        return 1
    fi

    for interface in "${interfaces[@]}"; do
        ip_addr=$(ip -o -4 addr show dev "$interface" 2>/dev/null | awk '{print $4}' | paste -sd ',' -)

        if [ -n "$ip_addr" ]; then
            menu_options+=("${interface}  ${GREEN}${ip_addr}${RESET}")
        else
            menu_options+=("${interface}")
        fi
    done

    echo "${BOLD}${CYAN}Available Wi-Fi interfaces:${RESET}"
    echo "${BLUE}GPS flag:${RESET} use ${BOLD}-g${RESET} or ${BOLD}--gps${RESET} to add ${BOLD}--gpsd ${GPSD_ENDPOINT}${RESET}"
    echo

    select menu_option in "${menu_options[@]}"; do
        if [[ "$REPLY" =~ ^[0-9]+$ ]] && [ -n "${menu_option:-}" ] && [ -n "${interfaces[$((REPLY - 1))]:-}" ]; then
            interface=${interfaces[$((REPLY - 1))]}
            break
        fi

        echo "${RED}Invalid option. Select a Wi-Fi interface.${RESET}"
    done

    echo
    echo "${GREEN}Selected interface:${RESET} ${BOLD}${interface}${RESET}"

    selected_ip=$(ip -o -4 addr show dev "$interface" 2>/dev/null | awk '{print $4}' | paste -sd ',' -)
    if [ -n "$selected_ip" ]; then
        echo "${GREEN}Interface IP:${RESET} ${BOLD}${selected_ip}${RESET}"
    fi

    cmd=(sudo "$HOME/.angry/angryoxide" -i "$interface")
    if [ "$USE_GPSD" -eq 1 ]; then
        cmd+=(--gpsd "$GPSD_ENDPOINT")
        echo "${GREEN}GPSD enabled:${RESET} ${BOLD}${GPSD_ENDPOINT}${RESET}"
    fi

    echo "${BLUE}Running:${RESET} ${cmd[*]}"
    "${cmd[@]}"
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        -i|--install)
            install_angryoxide
            exit $?
            ;;
        -g|--gps)
            USE_GPSD=1
            shift
            ;;
        -h|--help)
            show_usage
            exit 0
            ;;
        *)
            echo "${RED}Unknown option:${RESET} $1"
            show_usage
            exit 1
            ;;
    esac
done

if [ ! -f "$HOME/.angry/angryoxide" ]; then
    echo "${RED}File not found:${RESET} $HOME/.angry/angryoxide"
    echo "${YELLOW}Run this script with -i or --install to download it.${RESET}"
    exit 1
fi

choose_interface
