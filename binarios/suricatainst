#!/usr/bin/env bash
# Instala y configura Suricata con interfaz en modo promiscuo (auto/override)
# Uso opcional: IFACE=eth1 ./setup-suricata.sh  (o ./setup-suricata.sh eth1)

set -euo pipefail

# ===== Colores ANSI =====
G="\e[92m"; Y="\e[93m"; B="\e[94m"; R="\e[91m"; X="\e[0m"

echo -e "\n${B}──────────────────────────────────────────────────────────────${X}"
echo -e "${B}                 INSTALACIÓN • SURICATA (APT)                 ${X}"
echo -e "${B}──────────────────────────────────────────────────────────────${X}\n"

# ===== Select interface =====
ARG_IFACE="${1:-}"
ENV_IFACE="${IFACE:-}"

if [[ -n "$ARG_IFACE" ]]; then
  IFACE="$ARG_IFACE"
elif [[ -n "$ENV_IFACE" ]]; then
  IFACE="$ENV_IFACE"
else
  mapfile -t IFACES < <(ip -o link show up | awk -F': ' '{print $2}' | grep -v '^lo$')

  if [[ ${#IFACES[@]} -eq 0 ]]; then
    echo -e "${R}✖ No active interfaces found. Pass one: ${Y}./suricatainst eth1${X}\n"
    exit 1
  elif [[ ${#IFACES[@]} -eq 1 ]]; then
    IFACE="${IFACES[0]}"
  else
    echo ""
    echo -e "${Y}Multiple interfaces detected:${X}"
    for i in "${!IFACES[@]}"; do
      printf "  %d) %s\n" "$((i+1))" "${IFACES[$i]}"
    done
    echo ""
    read -rp "Select interface [1-${#IFACES[@]}]: " choice
    if [[ "$choice" -ge 1 && "$choice" -le ${#IFACES[@]} ]] 2>/dev/null; then
      IFACE="${IFACES[$((choice-1))]}"
    else
      echo -e "${R}Invalid selection.${X}"; exit 1
    fi
  fi
fi

echo -e "${G}✔ Using interface:${X} ${Y}${IFACE}${X}\n"

# ===== APT =====
echo -e "${G}→${X} ${Y}sudo apt update${X}\n"
sudo apt update -y

echo -e "${G}→${X} ${Y}sudo apt install suricata -y${X}\n"
sudo apt install -y suricata

# ===== Reglas =====
echo -e "${G}→${X} ${Y}sudo suricata-update${X}\n"
sudo suricata-update

# ===== Config: /etc/default/suricata =====
echo -e "${G}→${X} ${Y}Configurando /etc/default/suricata${X}\n"
sudo install -m 0644 /dev/null /etc/default/suricata || true
sudo tee /etc/default/suricata >/dev/null <<EOF
# Autogenerado: interfaz y opciones de Suricata
LISTENMODE=af-packet
IFACE="${IFACE}"
SURICATA_OPTIONS="-i \${IFACE}"
EOF
# ===== Set interface in suricata.yaml (af-packet section) =====
echo -e "${G}→${X} ${Y}Setting interface ${IFACE} in suricata.yaml${X}\n"
sudo sed -i '/^af-packet:/{n;s/- interface: .*/- interface: '"${IFACE}"'/;}' /etc/suricata/suricata.yaml

# ===== Ensure eve-log is enabled =====
echo -e "${G}→${X} ${Y}Verifying eve-log output is enabled${X}\n"
if grep -q '# *- eve-log:' /etc/suricata/suricata.yaml; then
  sudo sed -i 's/# *- eve-log:/- eve-log:/' /etc/suricata/suricata.yaml
fi

# ===== Promiscuous mode (current session + persistent) =====
echo -e "${G}→${X} ${Y}Enabling promiscuous mode on ${IFACE}${X}\n"
sudo ip link set "${IFACE}" promisc on

# Persist promiscuous mode across reboots
cat <<EOF | sudo tee /etc/systemd/system/promisc-${IFACE}.service >/dev/null
[Unit]
Description=Set promiscuous mode on ${IFACE}
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/sbin/ip link set ${IFACE} promisc on
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF
sudo systemctl daemon-reload
sudo systemctl enable promisc-${IFACE}.service

# ===== Probar sintaxis =====
echo -e "${G}→${X} ${Y}Validando configuración${X}\n"
sudo suricata -T -c /etc/suricata/suricata.yaml >/dev/null

# ===== Habilitar servicio =====
echo -e "${G}→${X} ${Y}sudo systemctl enable --now suricata${X}\n"
sudo systemctl enable --now suricata

# ===== Estado rápido =====
echo -e "${G}→${X} ${Y}systemctl --no-pager --full -l status suricata | sed -n '1,15p'${X}\n"
sudo systemctl --no-pager --full -l status suricata | sed -n '1,15p' || true

# ===== Final messages =====
echo
echo -e "${B}──────────────────────────────────────────────────────────────${X}"
echo -e "${G}✅ Suricata installed and running on interface:${X} ${Y}${IFACE}${X}\n"

echo -e "${Y}── Config files ────────────────────────────────────────${X}"
echo -e "  Main config:      ${Y}/etc/suricata/suricata.yaml${X}"
echo -e "  Default options:   ${Y}/etc/default/suricata${X}"
echo -e "  Rules:             ${Y}/var/lib/suricata/rules/${X}"

echo -e "\n${Y}── Logs ────────────────────────────────────────────────${X}"
echo -e "  Fast log:          ${Y}/var/log/suricata/fast.log${X}"
echo -e "  EVE JSON:          ${Y}/var/log/suricata/eve.json${X}"

echo -e "\n${Y}── Useful commands ─────────────────────────────────────${X}"
echo -e "  sudo systemctl status suricata"
echo -e "  sudo systemctl restart suricata"
echo -e "  sudo suricata-update              # update rules"
echo -e "  sudo suricata -T -c /etc/suricata/suricata.yaml  # validate config"
echo -e "  sudo tail -f /var/log/suricata/fast.log"

echo -e "\n${B}──────────────────────────────────────────────────────────────${X}\n"