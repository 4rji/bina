#!/usr/bin/env bash
echo -e "\n\033[1;34m_________________________________________________________\033[0m\n"
# Define output colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
PURPLE='\033[0;35m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[0;37m'
NC='\033[0m' # No color

# Show current user in blue
echo -e "${BLUE}Current user: $(whoami)${NC}"

# Function to display highlighted messages
echo_msg() {
    echo -e "${CYAN}==============================================${NC}"
    echo -e "${CYAN}$1${NC}"
    echo -e "${CYAN}==============================================${NC}"
}




# Function to lock a user
lock_user() {
    echo -e "${GREEN}Current users list:${NC}"
    # List users with a valid login shell
    awk -F: '$7 ~ /^\/(usr\/sbin\/nologin|bin\/false|bin\/(bash|sh)|usr\/bin\/zsh)[[:space:]]*$/ {print $1, $7}' /etc/passwd | column -t
    echo # Blank line for readability

    # Ask for username to lock
    read -p "User to lock and set to nologin: " user_to_lock

    # Check if the user exists
    if id "$user_to_lock" &>/dev/null; then
        # Show current state first
        echo -e "${GREEN}Current state:${NC}"
        echo ""
        sudo cat /etc/passwd | grep "$user_to_lock"
        # Lock user account (prevents login) and set nologin shell
        if sudo usermod -L "$user_to_lock" && sudo usermod -s /usr/sbin/nologin "$user_to_lock"; then
            echo -e "${RED}User '$user_to_lock' has been locked successfully.${NC}"
            # Show current user state
            echo -e "${GREEN}Current state for user '$user_to_lock':${NC}"
            sudo passwd -S "$user_to_lock"
            echo ""
            echo -e "${GREEN}Additional details for user '$user_to_lock':${NC}"
            sudo cat /etc/passwd | grep "$user_to_lock"
            echo -e "\n\033[1;33m_________________________________________________________\033[0m"
            echo -e "\033[1;33m_________________________________________________________\033[0m\n"
        else
            echo -e "${RED}There was an error while locking user '$user_to_lock'.${NC}"
        fi
    else
        echo -e "${RED}User '$user_to_lock' does not exist.${NC}"
    fi
}

# --- User lock option ---
read -p "Press [y] to lock a user or press Enter to continue: " option

if [[ "$option" =~ ^[yYsS]$ ]]; then
    while true; do
        lock_user
        read -p "Do you want to lock another user? [y/N]: " lock_another
        if [[ "$lock_another" =~ ^[yYsS]$ ]]; then
            continue
        fi
        break
    done
else
    echo "Continuing with the script..."
    echo -e "\n\033[1;33m_________________________________________________________\033[0m"
    echo -e "\033[1;33m_________________________________________________________\033[0m\n"
    # Continue with the rest of your script
fi

read -r -p "Do you want to create a user now? [Y/n]: " create_user_option
create_user_option="${create_user_option:-Y}"

if ! [[ "$create_user_option" =~ ^[YySs]$ ]]; then
    echo -e "${YELLOW}User creation skipped.${NC}"
    exit 0
fi

# --- Rest of your existing script ---
echo ""
# Ask for group name
echo ""
echo -e "${YELLOW}GROUP name (Example: developers):${NC}"
read -p "" group_name

# Validate that group name is not empty
if [[ -z "$group_name" ]]; then
    echo -e "${RED}Error: Group name cannot be empty.${NC}"
    exit 1
fi

# Ask for group ID
echo ""
echo -e "${GREEN}Enter Group ID (Example: 1234, numbers only):${NC}"
read -p "" group_id

# Validate that group ID is numeric
if ! [[ "$group_id" =~ ^[0-9]+$ ]]; then
    echo -e "${RED}Error: Group ID must be a valid number.${NC}"
    exit 1
fi

# Ask for username
echo ""
echo -e "${PURPLE}Enter USER name (Example: john_doe):${NC}"
read -p "" user_name

# Validate that username is not empty
if [[ -z "$user_name" ]]; then
    echo -e "${RED}Error: User name cannot be empty.${NC}"
    exit 1
fi

# Ask for user ID
echo ""
echo -e "${BLUE}Enter USER ID (Example: 1001, numbers only):${NC}"
read -p "" user_id

# Validate that user ID is numeric
if ! [[ "$user_id" =~ ^[0-9]+$ ]]; then
    echo -e "${RED}Error: User ID must be a valid number.${NC}"
    exit 1
fi

# User confirmation
echo ""
echo -e "${CYAN}Group:${NC} $group_name"
echo -e "${CYAN}Group ID:${NC} $group_id"
echo -e "${CYAN}User:${NC} $user_name"
echo -e "${CYAN}User ID:${NC} $user_id"
echo ""
read -r -p "Create this user with these values? [Y/n]: " confirmation
confirmation="${confirmation:-Y}"

if [[ "$confirmation" =~ ^[YySs]$ ]]; then
    echo ""
    echo -e "${WHITE}_________________________________________________________${NC}"
    echo ""

    # Create group
    echo_msg "Creating group '$group_name' with ID '$group_id'..."
    sudo groupadd -g "$group_id" "$group_name"

    echo ""
    # Create user
    echo_msg "Creating user '$user_name' with ID '$user_id'..."
    sudo useradd -u "$user_id" -g "$group_id" -s /bin/bash -m "$user_name"

    echo ""
    # Set password for the user
    echo_msg "Setting password for user '$user_name'..."
    sudo passwd "$user_name"

    echo ""
    # Edit sudoers file for the user
    echo_msg "Editing file /etc/sudoers.d/$user_name..."
    echo "$user_name ALL=(ALL:ALL) ALL" | sudo tee /etc/sudoers.d/"$user_name" > /dev/null

    echo ""
    echo -e "${WHITE}_________________________________________________________${NC}"
    echo ""

    # Show updated sudoers file
    echo_msg "Showing file /etc/sudoers.d/$user_name"
    echo ""
    sudo cat /etc/sudoers.d/"$user_name"
    echo ""
    echo -e "${GREEN}Done.${NC}"

    # Ask whether to switch to the created user
    echo ""
    read -n1 -p "Do you want to switch to the created user? [y/N] " answer
    echo ""

    # Switch to the created user if answer is affirmative
    if [[ "$answer" =~ ^[YySs]$ ]]; then
        echo -e "${YELLOW}Switching to user '$user_name'...${NC}"
        sudo su - "$user_name"
    fi

else
    echo ""
    echo -e "${RED}Operation canceled.${NC}"
fi

echo "sudo userdel -r username #remove home and everything"
echo "sudo userdel -f username #force"
