#!/usr/bin/env bash

set -e

CONFIG="/etc/systemd/logind.conf"
echo $CONFIG

echo ""
echo "📝 Agregando configuración para ignorar lid..."
sudo tee -a "$CONFIG" > /dev/null <<EOF

# Ignorar cierre de lid (no suspender/hibernar)
HandleLidSwitch=ignore
HandleLidSwitchExternalPower=ignore
HandleLidSwitchDocked=ignore
EOF

echo ""
echo "📄 Configuración actual del archivo:"
tail -5 "$CONFIG"

echo ""
echo "¿Reiniciar el servicio ahora? (S para sí, Enter para no)"
read -n1 input
echo

if [[ $input == "S" || $input == "s" ]]; then
    sudo systemctl restart systemd-logind
    echo "✅ Servicio reiniciado. Cambios aplicados."
else
    echo "⚠️  Cambios aplicarán en el próximo reinicio."
fi
