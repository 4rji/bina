#!/usr/bin/env bash
set -euo pipefail

# Color setup (enabled only if stdout is a terminal with color support).
if [[ -t 1 ]] && command -v tput >/dev/null 2>&1 && [[ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]]; then
  C_RESET=$'\033[0m'
  C_GREEN=$'\033[1;32m'
  C_YELLOW=$'\033[1;33m'
  C_RED=$'\033[1;31m'
  C_CYAN=$'\033[1;36m'
else
  C_RESET=""
  C_GREEN=""
  C_YELLOW=""
  C_RED=""
  C_CYAN=""
fi

progress_bar() {
  local used="$1"
  local width=24
  local filled=$((used * width / 100))
  local empty=$((width - filled))
  local bar
  printf -v bar "%${filled}s" ""
  bar=${bar// /#}
  printf -v bar "%s%${empty}s" "$bar" ""
  bar=${bar// /-}
  printf "[%s]" "$bar"
}

color_for_used() {
  local used="$1"
  if (( used >= 90 )); then
    printf "%s" "$C_RED"
  elif (( used >= 75 )); then
    printf "%s" "$C_YELLOW"
  else
    printf "%s" "$C_GREEN"
  fi
}

status_for_used() {
  local used="$1"
  if (( used >= 90 )); then
    printf "CRITICAL"
  elif (( used >= 75 )); then
    printf "WARNING"
  else
    printf "HEALTHY"
  fi
}

run_df() {
  local args_linux=(-hP -x tmpfs -x devtmpfs -x squashfs)
  local args_basic=(-hP)

  if df "${args_linux[@]}" >/dev/null 2>&1; then
    df "${args_linux[@]}"
    return 0
  fi

  if df "${args_basic[@]}" >/dev/null 2>&1; then
    df "${args_basic[@]}"
    return 0
  fi

  if command -v sudo >/dev/null 2>&1; then
    if sudo df "${args_linux[@]}" >/dev/null 2>&1; then
      sudo df "${args_linux[@]}"
      return 0
    fi

    if sudo df "${args_basic[@]}" >/dev/null 2>&1; then
      sudo df "${args_basic[@]}"
      return 0
    fi
  fi

  echo "Error: could not run df (and sudo is unavailable)." >&2
  return 1
}

main() {
  local df_output
  df_output="$(run_df)"

  echo -e "${C_CYAN}Disk Space Report (Linux)${C_RESET}"
  printf "%-22s %-10s %-10s %-10s %-6s %-6s %-10s %s\n" \
    "Mount Point" "Size" "Used" "Available" "Used%" "Free%" "Status" "Usage Bar"
  printf "%-22s %-10s %-10s %-10s %-6s %-6s %-10s %s\n" \
    "----------------------" "----------" "----------" "----------" "------" "------" "----------" "--------------------------"

  while IFS= read -r line; do
    # shellcheck disable=SC2086
    set -- $line
    local n="$#"
    local mount_idx="$n"
    local use_idx=$((n - 1))
    local avail_idx=$((n - 2))
    local used_idx=$((n - 3))
    local size_idx=$((n - 4))

    local size="${!size_idx}"
    local used="${!used_idx}"
    local avail="${!avail_idx}"
    local use_pct="${!use_idx}"
    local mount="${!mount_idx}"

    local used_num="${use_pct%%%}"
    local free_num=$((100 - used_num))
    local color
    local status
    local bar

    color="$(color_for_used "$used_num")"
    status="$(status_for_used "$used_num")"
    bar="$(progress_bar "$used_num")"

    printf "%b%-22s%b %-10s %-10s %-10s %5s  %5s  %-10s %s\n" \
      "$color" "$mount" "$C_RESET" "$size" "$used" "$avail" "${used_num}%" "${free_num}%" "$status" "$bar"
  done < <(
    printf "%s\n" "$df_output" \
      | tail -n +2 \
      | awk '{u=$(NF-1); gsub(/%/, "", u); print u "\t" $0}' \
      | sort -nr -k1,1 \
      | cut -f2-
  )
}

main "$@"
