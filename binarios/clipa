#!/usr/bin/env bash
set -euo pipefail

if [ $# -eq 0 ]; then
  echo "Uso: $0 <nombre_del_archivo>"
  exit 1
fi

if [ ! -e "$1" ]; then
  echo "El archivo '$1' no existe."
  exit 1
fi

case "$(uname -s)" in
  Darwin)
    copy_cmd="pbcopy"
    ;;
  Linux)
    if [ -n "${WAYLAND_DISPLAY:-}" ] && command -v wl-copy >/dev/null 2>&1; then
      copy_cmd="wl-copy"
    elif command -v xclip >/dev/null 2>&1; then
      copy_cmd="xclip -sel clip"
    elif command -v xsel >/dev/null 2>&1; then
      copy_cmd="xsel --clipboard --input"
    else
      echo "No hay clipboard tool. Instalá xclip, xsel o wl-clipboard." >&2
      exit 1
    fi
    ;;
  *)
    echo "OS no soportado: $(uname -s)" >&2
    exit 1
    ;;
esac

sed 's/\x1B\[[0-9;]*[a-zA-Z]//g' "$1" | eval "$copy_cmd"

echo "Contenido de '$1' copiado al portapapeles (sin ANSI)."
