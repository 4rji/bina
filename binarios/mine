#!/usr/bin/env bash
set -euo pipefail

show_info=0
[[ "${1:-}" == "-i" ]] && show_info=1

echo ""

case "$(uname -s)" in
  Darwin)
    if (( show_info )); then
      ifconfig | awk '
        /^[a-z0-9]+:/ { iface=substr($1, 1, length($1)-1) }
        /inet / && $2 != "127.0.0.1" {
          mask=$4; sub(/^0x/,"",mask); bits=0
          for(i=1;i<=length(mask);i++){
            c=substr(mask,i,1)
            v=index("0123456789abcdef",tolower(c))-1
            while(v){bits+=v%2;v=int(v/2)}
          }
          printf "\033[1;34m%s\033[0m: \033[1;32m%s/%d\033[0m\n", iface, $2, bits
        }'
    else
      ifconfig | awk '
        /^[a-z0-9]+:/ { iface=substr($1, 1, length($1)-1) }
        /inet / && $2 != "127.0.0.1" {
          printf "\033[1;34m%s\033[0m: \033[1;32m%s\033[0m\n", iface, $2
        }'
    fi
    if (( show_info )); then
      gw=$(route -n get default 2>/dev/null | awk '/gateway:/ {print $2}')
      dns=$(scutil --dns 2>/dev/null | awk '/nameserver\[/ {print $3}' | sort -u | tr '\n' ' ')
      printf "\033[1;34mDefault Route\033[0m: \033[1;33m%s\033[0m\n" "${gw:-N/A}"
      printf "\033[1;34mDNS\033[0m: \033[1;33m%s\033[0m\n" "${dns:-N/A}"
    fi
    ;;
  Linux)
    if (( show_info )); then
      ip -4 addr show | awk '/inet/ && !/127\.0\.0\.1/ {printf "\033[1;34m%s\033[0m: \033[1;32m%s\033[0m\n", $NF, $2}'
    else
      ip -4 addr show | awk '/inet/ && !/127\.0\.0\.1/ {split($2,a,"/"); printf "\033[1;34m%s\033[0m: \033[1;32m%s\033[0m\n", $NF, a[1]}'
    fi
    if (( show_info )); then
      gw=$(ip route show default 2>/dev/null | awk '/default/ {print $3; exit}')
      dns=""
      if command -v resolvectl >/dev/null 2>&1; then
        dns=$(resolvectl dns 2>/dev/null | awk -F: '/Link.*:/ {print $2}' | tr '\n' ' ' | xargs || true)
      fi
      [[ -z "$dns" ]] && dns=$(awk '/^nameserver/ {print $2}' /etc/resolv.conf 2>/dev/null | tr '\n' ' ' || true)
      printf "\033[1;34mDefault Route\033[0m: \033[1;33m%s\033[0m\n" "${gw:-N/A}"
      printf "\033[1;34mDNS\033[0m: \033[1;33m%s\033[0m\n" "${dns:-N/A}"
    fi
    ;;
  *)
    echo "OS no soportado: $(uname -s)" >&2
    exit 1
    ;;
esac

(( show_info )) || printf "\033[2mtip: run \033[0m\033[1;36mmine -i\033[0m\033[2m for subnet, default route and DNS\033[0m\n"

echo ""
