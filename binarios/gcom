#!/usr/bin/env bash

# Colores para mensajes del script
CYAN='\033[1;36m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
BLUE='\033[1;34m'
MAGENTA='\033[1;35m'
RESET='\033[0m'

# Mensaje del commit desde argumentos
MSG="$*"

# Si no hay mensaje, usa uno por defecto
if [ -z "$MSG" ]; then
    MSG="gcom"
fi

while true; do
    echo ""
    echo -e "${CYAN}==== gcom menu ====${RESET}"
    echo -e "${YELLOW}What do you want to do?${RESET}"
    echo -e "  ${GREEN}1${RESET}) Commit & push (add . + commit + push origin/backup)"
    echo -e "  ${GREEN}2${RESET}) Fetch from origin"
    echo -e "  ${GREEN}3${RESET}) Git pull from origin"
    echo -e "  ${GREEN}4${RESET}) Fetch all remotes"
    echo -e "  ${GREEN}5${RESET}) Git status"
    echo -e "  ${GREEN}q${RESET}) Quit"
    echo -ne "${MAGENTA}Choice: ${RESET}"

    read -rsn1 choice
    echo "$choice"

    case "$choice" in
        1)
            echo -e "${BLUE}>> Running commit & push...${RESET}"
            git add .
            git commit -m "$MSG"
            git push origin main
            git push backup main
            echo -e "${GREEN}>> Done.${RESET}"
            ;;
        2)
            echo -e "${BLUE}>> Fetching origin...${RESET}"
            git fetch origin
            echo -e "${GREEN}>> Done.${RESET}"
            ;;
        3)
            echo -e "${BLUE}>> Pulling from origin/main...${RESET}"
            git pull origin main
            echo -e "${GREEN}>> Done.${RESET}"
            ;;
        4)
            echo -e "${BLUE}>> Fetching all remotes...${RESET}"
            git fetch --all
            echo -e "${GREEN}>> Done.${RESET}"
            ;;
        5)
            echo -e "${BLUE}>> Git status:${RESET}"
            git status
            ;;
        q|Q)
            echo -e "${CYAN}Bye!${RESET}"
            exit 0
            ;;
        *)
            echo -e "${RED}Invalid option${RESET}"
            ;;
    esac
done
