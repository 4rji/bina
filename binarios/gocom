#!/usr/bin/env bash
set -euo pipefail

TARGET="${1:-.}"
MODULE_NAME="${2:-}"
GO_CACHE="${GO_CACHE:-/tmp/gocache}"

# Colores
RESET="\033[0m"
BOLD="\033[1m"
DIM="\033[2m"
RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
BLUE="\033[34m"
MAGENTA="\033[35m"
CYAN="\033[36m"

get_bin_name() {
  local target="$1"

  # Sin argumento o "."
  if [[ "$target" == "." ]]; then
    basename "$PWD"
    return
  fi

  # Si es archivo .go => quitar extension
  if [[ "$target" == *.go ]]; then
    basename "${target%.go}"
    return
  fi

  # Si es ruta/carpeta => usar nombre final de la ruta
  basename "$target"
}

BIN_NAME="$(get_bin_name "$TARGET")"

print_header() {
  clear 2>/dev/null || true
  echo -e "${BOLD}${CYAN}========================================${RESET}"
  echo -e "${BOLD}${CYAN}          Go Build Menu Cool            ${RESET}"
  echo -e "${BOLD}${CYAN}========================================${RESET}"
  echo -e "${DIM}Target      : ${TARGET}${RESET}"
  echo -e "${DIM}Module name : ${MODULE_NAME:-<no definido>}${RESET}"
  echo -e "${DIM}Binary name : ${BIN_NAME}${RESET}"
  echo
}

run_cmd() {
  echo -e "${YELLOW}$ $*${RESET}"
  "$@"
  echo -e "${GREEN}OK${RESET}"
}

pause_key() {
  echo
  echo -ne "${DIM}Pulsa cualquier tecla para volver al menú...${RESET}"
  IFS= read -r -s -n 1 _
}

step_1() {
  echo -e "${BOLD}=== Step 1: Initialize Go module ===${RESET}"
  if [[ -f go.mod ]]; then
    echo -e "${YELLOW}go.mod ya existe, ignorando este paso.${RESET}"
    return
  fi

  if [[ -z "${MODULE_NAME}" ]]; then
    echo -e "${RED}No pasaste MODULE_NAME.${RESET}"
    echo -e "${DIM}Uso: ./script [archivo.go|.] [module/name]${RESET}"
    echo -e "${DIM}Ejemplo: ./script . github.com/usuario/proyecto${RESET}"
    return 1
  fi

  run_cmd go mod init "${MODULE_NAME}"
}

step_2() {
  echo -e "${BOLD}=== Step 2: Download dependencies ===${RESET}"
  run_cmd go get github.com/AlecAivazis/survey/v2
  run_cmd go mod tidy
}

step_3() {
  echo -e "${BOLD}=== Step 3: Build (native, optimized) ===${RESET}"
  run_cmd go build -trimpath -ldflags "-s -w" -o "${BIN_NAME}" "${TARGET}"
}

step_4() {
  echo -e "${BOLD}=== Step 4: Optional UPX compression ===${RESET}"
  if ! command -v upx >/dev/null 2>&1; then
    echo -e "${RED}UPX no está instalado.${RESET}"
    echo -e "${DIM}Instálalo o salta este paso.${RESET}"
    return 0
  fi
  run_cmd upx --best --lzma "${BIN_NAME}"
}

step_5() {
  echo -e "${BOLD}=== Step 5: Cross-compile Linux amd64 (static, reproducible) ===${RESET}"
  echo -e "${YELLOW}$ GOCACHE=${GO_CACHE} CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags '-s -w' -o ${BIN_NAME} ${TARGET}${RESET}"
  GOCACHE="${GO_CACHE}" CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -trimpath -ldflags "-s -w" -o "${BIN_NAME}" "${TARGET}"
  echo -e "${GREEN}OK${RESET}"
}

step_6() {
  echo -e "${BOLD}=== Step 6: Vendor dependencies (offline builds) ===${RESET}"
  run_cmd go mod vendor
}

step_7() {
  echo -e "${BOLD}=== Step 7: Linux amd64 using vendor ===${RESET}"
  echo -e "${YELLOW}$ GOCACHE=${GO_CACHE} CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -mod=vendor -trimpath -ldflags '-s -w' -o ${BIN_NAME} ${TARGET}${RESET}"
  GOCACHE="${GO_CACHE}" CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -mod=vendor -trimpath -ldflags "-s -w" -o "${BIN_NAME}" "${TARGET}"
  echo -e "${GREEN}OK${RESET}"
}

step_8() {
  echo -e "${BOLD}=== Step 8: Windows amd64 ===${RESET}"
  echo -e "${YELLOW}$ GOOS=windows GOARCH=amd64 CGO_ENABLED=0 go build -trimpath -ldflags '-s -w' -o ${BIN_NAME}-windows-amd64.exe ${TARGET}${RESET}"
  GOOS=windows GOARCH=amd64 CGO_ENABLED=0 \
    go build -trimpath -ldflags "-s -w" -o "${BIN_NAME}-windows-amd64.exe" "${TARGET}"
  echo -e "${GREEN}OK${RESET}"
}

step_all() {
  if [[ ! -f go.mod && -n "${MODULE_NAME}" ]]; then
    step_1
  elif [[ ! -f go.mod && -z "${MODULE_NAME}" ]]; then
    echo -e "${YELLOW}No hay go.mod y no pasaste MODULE_NAME, salto Step 1.${RESET}"
  fi

  step_2
  step_3
  step_4 || true
  step_5
  step_6
  step_7
  step_8
}

show_menu() {
  print_header
  echo -e "${MAGENTA}1)${RESET} Initialize Go module"
  echo -e "${MAGENTA}2)${RESET} Download dependencies"
  echo -e "${MAGENTA}3)${RESET} Build (native, optimized)"
  echo -e "${MAGENTA}4)${RESET} Optional UPX compression"
  echo -e "${MAGENTA}5)${RESET} Cross-compile Linux amd64"
  echo -e "${MAGENTA}6)${RESET} Vendor dependencies"
  echo -e "${MAGENTA}7)${RESET} Linux amd64 using vendor"
  echo -e "${MAGENTA}8)${RESET} Windows amd64"
  echo -e "${MAGENTA}a)${RESET} Run all"
  echo -e "${MAGENTA}q)${RESET} Quit"
  echo
  echo -ne "${BOLD}Elige una opción [1-8, a, q]: ${RESET}"
}

# Verificar que se ejecuta en terminal interactiva
if [[ ! -t 0 ]]; then
  echo "Este script necesita una terminal interactiva."
  echo "Ejecuta asi: ./script.sh o bash script.sh"
  exit 1
fi

while true; do
  show_menu
  IFS= read -r -s -n 1 choice
  echo

  case "${choice}" in
    1) step_1; pause_key ;;
    2) step_2; pause_key ;;
    3) step_3; pause_key ;;
    4) step_4; pause_key ;;
    5) step_5; pause_key ;;
    6) step_6; pause_key ;;
    7) step_7; pause_key ;;
    8) step_8; pause_key ;;
    a|A) step_all; pause_key ;;
    q|Q) echo -e "${CYAN}Bye.${RESET}"; exit 0 ;;
    *) echo -e "${RED}Opción inválida.${RESET}"; pause_key ;;
  esac
done
