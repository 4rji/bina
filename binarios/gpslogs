#!/usr/bin/env bash
set -u

# ====== Config ======
IFACE="${1:-wlan1}"
OUTDIR="$HOME/wifi-gps-logs"
OUTFILE="$OUTDIR/wifi_gps_$(date +%F_%H-%M-%S).csv"
INTERVAL="${INTERVAL:-5}"

# ====== Colores (solo si stdout es terminal) ======
if [ -t 1 ]; then
  R=$'\033[0;31m'; G=$'\033[0;32m'; Y=$'\033[0;33m'
  C=$'\033[0;36m'; BOLD=$'\033[1m'; DIM=$'\033[2m'; NC=$'\033[0m'
else
  R=""; G=""; Y=""; C=""; BOLD=""; DIM=""; NC=""
fi

# ====== Contadores ======
TOTAL_RECORDS=0
TOTAL_SCANS=0
GPS_FIX_COUNT=0
GPS_NOFIX_COUNT=0

# ====== Resumen al salir ======
cleanup() {
  echo
  echo
  echo "${BOLD}${C}=== Resumen ===${NC}"
  echo "Escaneos realizados:  $TOTAL_SCANS"
  echo "Filas guardadas:      $TOTAL_RECORDS"
  echo "Con fix GPS:          ${G}$GPS_FIX_COUNT${NC}"
  echo "Sin fix:              ${Y}$GPS_NOFIX_COUNT${NC}"
  echo "Archivo: $OUTFILE"
  exit 0
}
trap cleanup INT TERM

# ====== Pre-flight ======
echo "${BOLD}${C}=== WiFi + GPS Logger ===${NC}"
echo

# Dependencias
missing=0
for cmd in gpspipe jq iw awk; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "${R}[FALTA]${NC} $cmd"
    missing=1
  fi
done
if [ "$missing" -eq 1 ]; then
  echo
  echo "Instala lo necesario:  sudo pacman -S gpsd jq iw"
  exit 1
fi

# Interfaz
if ! ip link show "$IFACE" >/dev/null 2>&1; then
  echo "${R}[ERROR]${NC} La interfaz '$IFACE' no existe"
  echo "Interfaces Wi-Fi disponibles:"
  iw dev 2>/dev/null | awk '$1=="Interface"{print "  - "$2}'
  exit 1
fi
echo "${G}[OK]${NC} Interfaz: $IFACE"

# gpsd corriendo
if systemctl is-active --quiet gpsd 2>/dev/null || pgrep -x gpsd >/dev/null 2>&1; then
  echo "${G}[OK]${NC} gpsd activo"
else
  echo "${Y}[WARN]${NC} gpsd no parece estar corriendo"
  echo "        sudo systemctl start gpsd.socket"
fi

# Sondeo inicial GPS
echo
echo "${BOLD}Sondeo inicial de GPS (5s)...${NC}"
GPS_TEST=$(timeout 5 gpspipe -w -n 30 2>/dev/null || true)

if [ -z "$GPS_TEST" ]; then
  echo "${R}[ERROR]${NC} No llegan datos desde gpsd"
  echo "        Revisa: ls /dev/tty{USB,ACM}*  y  /etc/default/gpsd"
  echo
  read -r -p "Continuar de todos modos (las filas saldrán sin lat/lon)? [s/N] " ans
  [[ "$ans" =~ ^[sS]$ ]] || exit 1
else
  TPV=$(echo "$GPS_TEST" | jq -rc 'select(.class=="TPV")' 2>/dev/null | tail -n 1)
  SKY=$(echo "$GPS_TEST" | jq -rc 'select(.class=="SKY")' 2>/dev/null | tail -n 1)

  if [ -n "$TPV" ]; then
    MODE_T=$(echo "$TPV" | jq -r '.mode // 0')
    LAT_T=$(echo "$TPV"  | jq -r '.lat  // "—"')
    LON_T=$(echo "$TPV"  | jq -r '.lon  // "—"')
    case "$MODE_T" in
      3) echo "${G}[OK]${NC}    Fix 3D: $LAT_T, $LON_T" ;;
      2) echo "${Y}[OK]${NC}    Fix 2D: $LAT_T, $LON_T" ;;
      *) echo "${Y}[WARN]${NC} Sin fix todavía (mode=$MODE_T) — prueba con cielo despejado" ;;
    esac
  else
    echo "${Y}[WARN]${NC} Llegan datos de gpsd pero aún no hay TPV"
  fi

  if [ -n "$SKY" ]; then
    NSAT=$(echo "$SKY" | jq -r '.satellites | length // 0' 2>/dev/null)
    USED=$(echo "$SKY" | jq -r '[.satellites[]? | select(.used==true)] | length' 2>/dev/null)
    echo "        Satélites: ${USED:-0} usados / ${NSAT:-0} vistos"
  fi
fi

# ====== Init salida ======
mkdir -p "$OUTDIR"
echo "timestamp,lat,lon,mode,sats_used,sats_seen,bssid,ssid,signal_dbm,freq_mhz,channel" > "$OUTFILE"

echo
echo "Salida CSV: ${BOLD}$OUTFILE${NC}"
echo "Intervalo:  ${INTERVAL}s"
echo "Ctrl+C para detener."
echo
printf "${DIM}%-8s  %-6s  %-24s  %-9s  %-9s  %s${NC}\n" \
  "Hora" "Fix" "Coordenadas" "Sats U/V" "Wi-Fi" "Total"
printf "${DIM}%-8s  %-6s  %-24s  %-9s  %-9s  %s${NC}\n" \
  "--------" "------" "------------------------" "---------" "---------" "-----"

# ====== Lector GPS ======
# Devuelve: lat,lon,mode,sats_used,sats_seen
get_gps() {
  local data tpv tpv_any sky lat lon mode used seen
  data=$(timeout 3 gpspipe -w -n 15 2>/dev/null || true)
  if [ -z "$data" ]; then echo ",,0,,"; return; fi

  tpv=$(echo "$data" | jq -rc 'select(.class=="TPV") | select(.lat!=null and .lon!=null)' 2>/dev/null | tail -n 1)
  sky=$(echo "$data" | jq -rc 'select(.class=="SKY")' 2>/dev/null | tail -n 1)

  if [ -n "$tpv" ]; then
    lat=$(echo "$tpv"  | jq -r '.lat')
    lon=$(echo "$tpv"  | jq -r '.lon')
    mode=$(echo "$tpv" | jq -r '.mode // 0')
  else
    tpv_any=$(echo "$data" | jq -rc 'select(.class=="TPV")' 2>/dev/null | tail -n 1)
    lat=""; lon=""
    mode=$(echo "$tpv_any" | jq -r '.mode // 0' 2>/dev/null)
    [ -z "$mode" ] && mode=0
  fi

  if [ -n "$sky" ]; then
    seen=$(echo "$sky" | jq -r '.satellites | length // 0')
    used=$(echo "$sky" | jq -r '[.satellites[]? | select(.used==true)] | length')
  else
    seen=""; used=""
  fi

  echo "$lat,$lon,$mode,$used,$seen"
}

fix_label() {
  case "$1" in
    3) echo "${G}3D${NC}  " ;;
    2) echo "${Y}2D${NC}  " ;;
    *) echo "${R}NONE${NC}" ;;
  esac
}

# ====== Loop principal ======
while true; do
  TS="$(date --iso-8601=seconds)"
  GPS_DATA="$(get_gps)"
  LAT="$(echo  "$GPS_DATA" | cut -d, -f1)"
  LON="$(echo  "$GPS_DATA" | cut -d, -f2)"
  MODE="$(echo "$GPS_DATA" | cut -d, -f3)"
  USED="$(echo "$GPS_DATA" | cut -d, -f4)"
  SEEN="$(echo "$GPS_DATA" | cut -d, -f5)"

  if [ "$MODE" = "2" ] || [ "$MODE" = "3" ]; then
    GPS_FIX_COUNT=$((GPS_FIX_COUNT+1))
  else
    GPS_NOFIX_COUNT=$((GPS_NOFIX_COUNT+1))
  fi

  SCAN_OUT=$(sudo iw dev "$IFACE" scan 2>/dev/null || true)

  ROWS_THIS_SCAN=$(echo "$SCAN_OUT" | awk \
    -v ts="$TS" -v lat="$LAT" -v lon="$LON" -v mode="$MODE" \
    -v used="$USED" -v seen="$SEEN" -v outfile="$OUTFILE" '
    function clean(s) { gsub(/"/, "\"\"", s); return "\"" s "\"" }
    function emit() {
      if (bssid != "") {
        print ts "," lat "," lon "," mode "," used "," seen "," bssid "," clean(ssid) "," signal "," freq "," channel >> outfile
        n++
      }
    }
    /^BSS / {
      emit()
      bssid=$2; gsub(/\(.*/, "", bssid)
      ssid=""; signal=""; freq=""; channel=""
    }
    /^[ \t]*SSID:/             { ssid=$0; sub(/^[ \t]*SSID:[ \t]*/, "", ssid) }
    /^[ \t]*signal:/            { signal=$2 }
    /^[ \t]*freq:/              { freq=$2 }
    /^[ \t]*DS Parameter set:/  { channel=$5 }
    END { emit(); print (n+0) }
  ')
  ROWS_THIS_SCAN=$(echo "$ROWS_THIS_SCAN" | tr -dc '0-9')
  ROWS_THIS_SCAN="${ROWS_THIS_SCAN:-0}"

  TOTAL_RECORDS=$((TOTAL_RECORDS + ROWS_THIS_SCAN))
  TOTAL_SCANS=$((TOTAL_SCANS + 1))

  if [ -n "$LAT" ] && [ -n "$LON" ]; then
    COORD=$(printf "%.5f, %.5f" "$LAT" "$LON" 2>/dev/null || echo "$LAT, $LON")
  else
    COORD="—"
  fi
  SATS="${USED:-?}/${SEEN:-?}"
  HMS="${TS#*T}"; HMS="${HMS:0:8}"

  printf "%-8s  %s  %-24s  %-9s  %3d nets   ${DIM}%d${NC}\n" \
    "$HMS" "$(fix_label "$MODE")" "$COORD" "$SATS" "$ROWS_THIS_SCAN" "$TOTAL_RECORDS"

  sleep "$INTERVAL"
done
