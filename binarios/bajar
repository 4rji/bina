#!/usr/bin/env bash

# colors
RED="\033[1;31m"
GREEN="\033[1;32m"
YELLOW="\033[1;33m"
CYAN="\033[1;36m"
RESET="\033[0m"

show_help() {
  echo -e "${CYAN}Usage:${RESET} $0 [option] <URL>\n"
  echo -e "${YELLOW}Options:${RESET}"
  echo -e "  ${GREEN}-3${RESET}   Download best audio as MP3"
  echo -e "  ${GREEN}-4${RESET}   Download best video (highest quality)"
  echo -e "  ${GREEN}-v${RESET}   Stream/play in best quality with mpv\n"
  echo -e "${CYAN}Example:${RESET}"
  echo -e "  $0 -4 https://youtube.com/...\n"
}

# need at least 2 args
if [ $# -lt 2 ]; then
  show_help
  exit 1
fi

OPTION="$1"
URL="$2"

case "$OPTION" in
  -3)
    yt-dlp -f bestaudio -x --audio-format mp3 --audio-quality 0 "$URL"
    ;;
  -4)
    yt-dlp -f "bestvideo+bestaudio/best" "$URL"
    ;;
  -v)
    mpv --ytdl-format="bestvideo+bestaudio/best" "$URL"
    ;;
  *)
    echo -e "${RED}Invalid option${RESET}\n"
    show_help
    exit 1
    ;;
esac
