#!/usr/bin/env bash
set -euo pipefail

ask_yn() {
  local prompt="$1" default="${2:-y}" ans
  read -r -p "$prompt" ans || true
  ans="${ans:-$default}"
  ans="$(echo "$ans" | tr '[:upper:]' '[:lower:]')"
  [[ "$ans" == "y" || "$ans" == "s" ]]
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || { echo "Missing dependency: $1" >&2; exit 1; }
}

# --- deps ---
need_cmd curl
need_cmd git

# --- install zsh if missing ---
if ! command -v zsh >/dev/null 2>&1; then
  if ask_yn "Install zsh? [Y/n]: " "y"; then
    if command -v apt-get >/dev/null 2>&1; then
      sudo apt-get update -y
      sudo apt-get install -y zsh
    elif command -v dnf >/dev/null 2>&1; then
      sudo dnf install -y zsh
    elif command -v pacman >/dev/null 2>&1; then
      sudo pacman -Sy --noconfirm zsh
    else
      echo "No supported package manager found (apt/dnf/pacman)." >&2
      exit 1
    fi
  else
    exit 0
  fi
fi

# --- install oh-my-zsh if missing ---
if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
  if ask_yn "Install Oh My Zsh? [Y/n]: " "y"; then
    RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
      sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
  fi
fi

ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

# --- powerlevel10k theme ---
if ask_yn "Install/Update Powerlevel10k theme? [Y/n]: " "y"; then
  if [[ -d "$ZSH_CUSTOM/themes/powerlevel10k/.git" ]]; then
    git -C "$ZSH_CUSTOM/themes/powerlevel10k" pull --ff-only
  else
    git clone https://github.com/romkatv/powerlevel10k.git "$ZSH_CUSTOM/themes/powerlevel10k"
  fi
fi



# --- plugins ---
install_or_update_plugin() {
  local name="${1:-}"
  local repo="${2:-}"

  if [[ -z "$name" || -z "$repo" ]]; then
    echo "install_or_update_plugin: missing args (name/repo)" >&2
    return 1
  fi

  local dir="$ZSH_CUSTOM/plugins/$name"

  if [[ -d "$dir/.git" ]]; then
    git -C "$dir" pull --ff-only
  else
    git clone "$repo" "$dir"
  fi
}
# --- 4rji: bashfun (functions + zsh config) ---
install_bashfun_4rji() {
  local url="https://raw.githubusercontent.com/4rji/bina/main/binarios/bashfun"

  command -v python3 >/dev/null 2>&1 || { echo "python3 missing"; return 1; }
  command -v curl >/dev/null 2>&1 || { echo "curl missing"; return 1; }

  echo "[*] Installing 4rji bashfun into ~/.zshrc"
  python3 <(curl -fsSL "$url")
}

# --- 4rji: PATH + aliases ---
install_path_and_aliases_4rji() {
  local zshrc="$HOME/.zshrc"
  local bin_dir="/opt/4rji/bin"
  local alias_url="https://raw.githubusercontent.com/4rji/4rji/main/alias.sh"

  [[ -f "$zshrc" ]] || touch "$zshrc"

	 # PATH (no duplicar)
	if ask_yn "Add $bin_dir to PATH in ~/.zshrc? [Y/n]: " "y"; then
	  if ! grep -qF "export PATH=\$PATH:$bin_dir" "$zshrc"; then
	    echo "export PATH=\$PATH:$bin_dir" >> "$zshrc"
	    echo "[*] Added PATH line"
	  else
	    echo "[*] PATH already present"
	  fi
	fi

	# Alias
	if ask_yn "Install all aliases? [Y/n]: " "y"; then
	  if command -v curl >/dev/null 2>&1; then
	    curl -fsSL "$alias_url" | bash
	  elif command -v wget >/dev/null 2>&1; then
	    wget -qO- "$alias_url" | bash
	  else
	    echo "Need curl or wget to install aliases"
	    
      return 1
    fi
  fi
}




if ask_yn "Install/Update zsh plugins (autosuggestions, syntax-highlighting)? [Y/n]: " "y"; then
  install_or_update_plugin "zsh-autosuggestions" "https://github.com/zsh-users/zsh-autosuggestions"
  install_or_update_plugin "zsh-syntax-highlighting" "https://github.com/zsh-users/zsh-syntax-highlighting.git"
fi

# --- edit ~/.zshrc ---
ZSHRC="$HOME/.zshrc"
[[ -f "$ZSHRC" ]] || touch "$ZSHRC"

# theme
if grep -qE '^ZSH_THEME=' "$ZSHRC"; then
  sed -i 's/^ZSH_THEME=.*/ZSH_THEME="powerlevel10k\/powerlevel10k"/' "$ZSHRC"
else
  echo 'ZSH_THEME="powerlevel10k/powerlevel10k"' >> "$ZSHRC"
fi

# plugins line (simple replace if exists; otherwise append)
if grep -qE '^plugins=\(' "$ZSHRC"; then
  sed -i 's/^plugins=(.*)$/plugins=(git zsh-autosuggestions zsh-syntax-highlighting sudo)/' "$ZSHRC"
else
  echo 'plugins=(git zsh-autosuggestions zsh-syntax-highlighting sudo)' >> "$ZSHRC"
fi

# --- p10k config + host_nombre ---
P10K_FILE="$HOME/.p10k.zsh"
if [[ -f "$P10K_FILE" ]]; then
  cp -a "$P10K_FILE" "${P10K_FILE}.bak.$(date +%Y%m%d-%H%M%S)"
fi

curl -fsSL -o "$P10K_FILE" "https://raw.githubusercontent.com/4rji/archivos-b/main/p10k.zsh"

if ! grep -qE '^export host_nombre=' "$ZSHRC"; then
  read -r -p "Value for host_nombre: " host_nombre
  echo "export host_nombre='$host_nombre'" >> "$ZSHRC"
fi

# add function at top if not already present
if ! grep -q 'function prompt_hola' "$P10K_FILE"; then
  tmp="$(mktemp)"
  cat >"$tmp" <<'EOF'
function prompt_hola() {
  p10k segment -f 208 -t "$host_nombre"
}

EOF
  cat "$tmp" "$P10K_FILE" > "${P10K_FILE}.tmp" && mv "${P10K_FILE}.tmp" "$P10K_FILE"
  rm -f "$tmp"
fi

# --- change default shell (optional) ---
if ask_yn "Change your default shell to zsh (chsh)? [Y/n]: " "y"; then
  zsh_path="$(command -v zsh)"
  if command -v chsh >/dev/null 2>&1; then
    # may prompt for password depending on system
    chsh -s "$zsh_path" || echo "chsh failed (you can run it manually): chsh -s $zsh_path"
  else
    echo "chsh not available. You can still run zsh manually."
  fi
fi

