#!/usr/bin/env bash

if [[ $# -eq 0 ]]; then
  echo "Usage:"
  echo "  script.sh <input.pdf>        Convert PDF to Markdown"
  echo "  script.sh -r                 Reinstall markitdown (fix broken install)"
  exit 1
fi

if [[ "$1" == "-r" ]]; then
  rm -f ~/.amigo/bin/markitdown
  pip install --no-cache-dir markitdown
  exit 0
fi

input="$1"
output="${input%.pdf}.md"

markitdown "$input" > "$output"