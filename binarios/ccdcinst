#!/usr/bin/env bash
set -euo pipefail

# Colors
GREEN='\e[0;32m'
BLUE='\e[0;34m'
YELLOW='\e[0;33m'
RESET='\e[0m'

BIN_DIR="/opt/4rji/bin"
REPO_URL="https://github.com/4rji/bina.git"
ALIAS_SCRIPT_URL="https://raw.githubusercontent.com/4rji/4rji/main/aliasbash.sh"
TMP_BASE="/dev/shm"

add_path_bashrc() {
  local line='export PATH="$PATH:/opt/4rji/bin"'
  local bashrc="$HOME/.bashrc"

  [[ -f "$bashrc" ]] || touch "$bashrc"

  if grep -Fqx "$line" "$bashrc"; then
    echo -e "${BLUE}[*] PATH already present in ~/.bashrc${RESET}"
  else
    echo "$line" >> "$bashrc"
    echo -e "${GREEN}[+] Added to ~/.bashrc:${RESET} $line"
  fi

  echo
  echo -e "${YELLOW}To activate now:${RESET}"
  echo "  source ~/.bashrc"
}

download_binaries() {
  echo -e "\n${BLUE}_________________________________________________________${RESET}\n"
  echo -e "${BLUE}[*] Downloading binaries (bina → ${BIN_DIR})...${RESET}"

  local tmpdir
  tmpdir="$(mktemp -d "${TMP_BASE}/tmp.bina.XXXXXX")"
  trap '[[ -n "${tmpdir:-}" && -d "${tmpdir:-}" ]] && rm -rf "$tmpdir"' EXIT

  git clone --depth 1 "$REPO_URL" "$tmpdir/bina"
  sudo mkdir -p "$BIN_DIR"

  if [[ -d "$tmpdir/bina/binarios" ]]; then
    sudo cp -rf "$tmpdir/bina/binarios/"* "$BIN_DIR/"
  else
    echo -e "${YELLOW}[!] binarios/ directory not found in repo${RESET}" >&2
    exit 1
  fi

  echo -e "${GREEN}[+] Binaries updated in ${BIN_DIR}${RESET}"
}

install_aliases_from_github() {
  echo -e "\n${BLUE}_________________________________________________________${RESET}\n"
  echo -e "${BLUE}[*] Installing bash aliases from GitHub...${RESET}"

  local tmp_alias
  tmp_alias="$(mktemp -p "$TMP_BASE" aliasbash.XXXXXX.sh)"

  # keep existing trap behavior + cleanup this file too
  trap '[[ -n "${tmp_alias:-}" && -f "${tmp_alias:-}" ]] && rm -f "$tmp_alias"; [[ -n "${tmpdir:-}" && -d "${tmpdir:-}" ]] && rm -rf "$tmpdir"' EXIT

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$ALIAS_SCRIPT_URL" -o "$tmp_alias"
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "$tmp_alias" "$ALIAS_SCRIPT_URL"
  else
    echo -e "${YELLOW}[!] Need curl or wget to fetch alias script:${RESET} $ALIAS_SCRIPT_URL" >&2
    exit 1
  fi

  chmod +x "$tmp_alias"

  # Run it with bash explicitly (in case it has a different shebang)
  bash "$tmp_alias"

  echo -e "${GREEN}[+] Aliases installed via:${RESET} $ALIAS_SCRIPT_URL"
}

main() {
  download_binaries
  add_path_bashrc
  install_aliases_from_github

  echo
  echo -e "${YELLOW}IMPORTANT:${RESET}"
  echo "Changes were written to your shell config."
  echo "They do NOT affect the current terminal session."
  echo
  echo "Apply now:"
  echo "  source ~/.bashrc"
  echo
  echo "Or open a new terminal."
}

main "$@"