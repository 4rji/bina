#!/usr/bin/env bash
set -euo pipefail

# Colors
GREEN='\e[0;32m'
BLUE='\e[0;34m'
YELLOW='\e[0;33m'
RESET='\e[0m'

BIN_DIR="/opt/4rji/bin"
REPO_URL="https://github.com/4rji/todo.git"
ALIAS_SCRIPT_URL="https://raw.githubusercontent.com/4rji/4rji/main/aliasbash.sh"
TMP_BASE="/dev/shm"

#autocompletition -  autocomplete bash
#sudo apt install bash-completion   # debian/ubuntu


# Lista de paquetes a instalar
#paquetes=("bash-completion" "oracle-epel-release-el9")

# Función para verificar si un paquete está instalado (Debian/Ubuntu/Kali)
paquete_instalado_apt() {  
    dpkg -l "$1" | grep -q '^ii'   2>/dev/null
}

# Función para verificar si un paquete está instalado (CentOS/RHEL)
paquete_instalado_yum() {
    yum list installed "$1" 2> /dev/null
}

# Función para verificar si un paquete está instalado (Fedora)
paquete_instalado_dnf() {
    dnf list installed "$1" 2> /dev/null
}

# Función para verificar si un paquete está instalado (Arch Linux)
paquete_instalado_pacman() {
    pacman -Qi "$1" 2> /dev/null
}

# Detectar el sistema operativo
if [ -f /etc/os-release ]; then
    . /etc/os-release
    OS=$ID
fi

# Instalar paquetes basados en el sistema operativo
for paquete in "${paquetes[@]}"; do
    case $OS in
        "debian"|"ubuntu"|"kali")
            if ! paquete_instalado_apt "$paquete"; then
                echo "Instalando el paquete $paquete..."
                sudo apt-get install -y "$paquete"  2>/dev/null
            fi
            ;;
        "centos"|"rhel")
            if ! paquete_instalado_yum "$paquete"; then
                echo "Instalando el paquete $paquete..."
                sudo yum install -y "$paquete" 2>/dev/null
            fi
            ;;
        "fedora")
            if ! paquete_instalado_dnf "$paquete"; then
                echo "Instalando el paquete $paquete..."
                sudo dnf install -y "$paquete" 2>/dev/null
            fi
            ;;
        "arch")
            if ! paquete_instalado_pacman "$paquete"; then
                echo "Instalando el paquete $paquete..."
                sudo pacman -S --noconfirm "$paquete" 2>/dev/null
            fi
            ;;
        *)
            ;;
    esac
done



add_path_bashrc() {
  local line_bin='export PATH="$PATH:/opt/4rji/bin"'
  local line_clamav='export PATH="/usr/local/clamav/bin:$PATH"'
  local bashrc="$HOME/.bashrc"

  [[ -f "$bashrc" ]] || touch "$bashrc"

  if grep -Fqx "$line_bin" "$bashrc"; then
    echo -e "${BLUE}[*] PATH already present in ~/.bashrc:${RESET} $line_bin"
  else
    echo "$line_bin" >> "$bashrc"
    echo -e "${GREEN}[+] Added to ~/.bashrc:${RESET} $line_bin"
  fi

  if grep -Fqx "$line_clamav" "$bashrc"; then
    echo -e "${BLUE}[*] PATH already present in ~/.bashrc:${RESET} $line_clamav"
  else
    echo "$line_clamav" >> "$bashrc"
    echo -e "${GREEN}[+] Added to ~/.bashrc:${RESET} $line_clamav"
  fi

  echo
  echo -e "${YELLOW}To activate now:${RESET}"
  echo "  source ~/.bashrc"
}

download_binaries() {
  echo -e "\n${BLUE}_________________________________________________________${RESET}\n"
  echo -e "${BLUE}[*] Downloading binaries (bina → ${BIN_DIR})...${RESET}"

  local tmpdir
  tmpdir="$(mktemp -d "${TMP_BASE}/tmp.bina.XXXXXX")"
  trap '[[ -n "${tmpdir:-}" && -d "${tmpdir:-}" ]] && rm -rf "$tmpdir"' EXIT

  git clone --depth 1 "$REPO_URL" "$tmpdir/todo"
  sudo mkdir -p "$BIN_DIR"

  if [[ -d "$tmpdir/todo/binarios" ]]; then
    sudo cp -rf "$tmpdir/todo/binarios/"* "$BIN_DIR/"
  else
    echo -e "${YELLOW}[!] binarios/ directory not found in repo${RESET}" >&2
    exit 1
  fi

  echo -e "${GREEN}[+] Binaries updated in ${BIN_DIR}${RESET}"
}

install_aliases_from_github() {
  echo -e "\n${BLUE}_________________________________________________________${RESET}\n"
  echo -e "${BLUE}[*] Installing bash aliases from GitHub...${RESET}"

  local tmp_alias
  tmp_alias="$(mktemp -p "$TMP_BASE" aliasbash.XXXXXX.sh)"

  # keep existing trap behavior + cleanup this file too
  trap '[[ -n "${tmp_alias:-}" && -f "${tmp_alias:-}" ]] && rm -f "$tmp_alias"; [[ -n "${tmpdir:-}" && -d "${tmpdir:-}" ]] && rm -rf "$tmpdir"' EXIT

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$ALIAS_SCRIPT_URL" -o "$tmp_alias"
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "$tmp_alias" "$ALIAS_SCRIPT_URL"
  else
    echo -e "${YELLOW}[!] Need curl or wget to fetch alias script:${RESET} $ALIAS_SCRIPT_URL" >&2
    exit 1
  fi

  chmod +x "$tmp_alias"

  # Run it with bash explicitly (in case it has a different shebang)
  bash "$tmp_alias"

  echo -e "${GREEN}[+] Aliases installed via:${RESET} $ALIAS_SCRIPT_URL"
}

main() {
  download_binaries
  add_path_bashrc
  install_aliases_from_github

  echo
  echo -e "${YELLOW}IMPORTANT:${RESET}"
  echo "Changes were written to your shell config."
  echo "They do NOT affect the current terminal session."
  echo
  echo "Apply now:"
  echo "  source ~/.bashrc"
  echo
  echo "Or open a new terminal."
}

main "$@"
